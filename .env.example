# Host-side ports for docker-exposed services (override to avoid conflicts on dev machines)
WORKER_PORT=4100
REDIS_PORT=4101
DB_PORT=4102
CLICKHOUSE_PORT=4103
WEB_PORT=4104

# Local defaults: docker-compose overrides these internally with container hostnames.
DATABASE_URL=postgresql://postgres:postgres@localhost:4102/oneglanse
CLICKHOUSE_URL=http://localhost:4103
REDIS_HOST=localhost
REDIS_PASSWORD=redis
APP_URL=http://localhost:4104
API_BASE_URL=http://localhost:4104

# App mode: overridden automatically by pnpm local (forces "local") and docker-compose (forces "self-host")
ONEGLANSE_APP_MODE=local

# Docker service defaults used by `pnpm self-host`
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=oneglanse
CLICKHOUSE_DB=oneglanse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse

# App secrets
# `pnpm local`, `pnpm auth`, and `pnpm self-host` auto-generate these when
# creating a fresh `.env` from this template.
BETTER_AUTH_SECRET=replace-me
INTERNAL_CRON_SECRET=replace-me

# Google OAuth: required for Google sign-in to the OneGlanse web app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Which LLM to use for response analysis: "openai" (default) or "claude"
ANALYSIS_LLM_PROVIDER=openai

# Optional auth-session upload target used by `pnpm auth` / `pnpm upload:vps`
# If AGENT_AUTH_UPLOAD_URL is not set, the auth helper derives:
#   http://<ONEGLANSE_VPS_IP>:4100/auth/sessions
ONEGLANSE_VPS_IP=
AGENT_AUTH_UPLOAD_TOKEN=

# Proxy: required on VPS (direct connection is not permitted)
# OneGlanse uses ThorData residential proxies. Set your ThorData API endpoint below.
# THORDATA_PROXY_API_URL=
# PROXY_SCHEME=http

# Optional agent/runtime overrides
# DEBUG_ENABLED=true
# CAMOUFOX_HEADLESS_MODE=virtual
# CAMOUFOX_PYTHON_BIN=
# CAMOUFOX_PIP_SPEC=cloverlabs-camoufox==0.5.5
# CAMOUFOX_BROWSER_CHANNEL=official/stable/135.0.1-beta.24

# Self-hosted storage root (volume mount path on the host)
ONEGLANSE_STORAGE_ROOT=/opt/oneglanse/storage

# Optional: override the published image names (e.g. when self-hosting a fork).
# Defaults point to the official prebuilt images published to GHCR on every release.
ONEGLANSE_AGENT_IMAGE=
ONEGLANSE_WEB_IMAGE=
ONEGLANSE_POSTGRES_IMAGE=
