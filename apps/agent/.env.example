# Redis (local)
REDIS_HOST=redis
REDIS_PORT=6379

# Proxy: use either PROXY_URL or the split PROXY_* fields below.
# Supported schemes: http, https, socks4, socks5
# PROXY_URL=http://user:pass@127.0.0.1:8080
PROXY_SCHEME=http
PROXY_HOST=127.0.0.1
PROXY_PORT=8080
# PROXY_USERNAME=your-username
# PROXY_PASSWORD=your-password

# Optional browser fingerprint alignment
# BROWSER_LOCALE=en-US
# BROWSER_TIMEZONE=America/New_York
# BROWSER_ACCEPT_LANGUAGE=en-US,en;q=0.9

DEBUG_ENABLED=false
