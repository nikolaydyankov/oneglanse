# Redis (local)
REDIS_HOST=redis
REDIS_PORT=6379

# Proxy: use either PROXY_URL or the split PROXY_* fields below.
# Supported schemes: http, https, socks4, socks5
# PROXY_PROVIDER=generic
# Supported providers:
# generic, decodo, smartproxy, brightdata, oxylabs, thordata,
# lunaproxy, netnut, soax, scrapeops, proxyempire, iproyal, webshare
#
# Start from the base endpoint/credentials from your provider dashboard.
# The agent rewrites only the documented sticky-session token for the provider.
#
# Decodo / Smartproxy:
# HTTP sticky ports:
# PROXY_PROVIDER=decodo
# PROXY_SCHEME=http
# PROXY_HOST=us.decodo.com
# PROXY_PORT=10001
# PROXY_USERNAME=user-abc
# PROXY_PASSWORD=pass-abc
# Alternative username/subdomain sessions:
# PROXY_URL=http://user-abc-session-old-sessionduration-30:pass-abc@gate.decodo.com:7000
#
# Bright Data:
# PROXY_PROVIDER=brightdata
# PROXY_URL=http://brd-customer-CUSTOMER-zone-ZONE-session-old:password@brd.superproxy.io:33335
#
# Oxylabs:
# Sticky port example:
# PROXY_PROVIDER=oxylabs
# PROXY_URL=http://customer-USERNAME:PASSWORD@us-pr.oxylabs.io:10001
# If your username already includes -sessid-..., the agent replaces that token too.
#
# Thordata:
# PROXY_PROVIDER=thordata
# PROXY_URL=http://td-customer-USERNAME-country-US-sessid-old-sesstime-10:password@treyklah.na.thordata.net:9999
#
# LunaProxy:
# PROXY_PROVIDER=lunaproxy
# PROXY_URL=http://user-USERNAME-region-us-sessid-old-sesstime-10:password@rw.lunaproxy.com:12233
#
# NetNut:
# Use the dashboard-generated base username and let the agent append/replace sid.
# PROXY_PROVIDER=netnut
# PROXY_URL=http://USERNAME-res-us:password@gw.netnut.net:5959
#
# SOAX:
# PROXY_PROVIDER=soax
# PROXY_URL=http://package-12345-country-us-sessionid-old-sessionlength-300:password@proxy.soax.com:5000
#
# ScrapeOps:
# PROXY_PROVIDER=scrapeops
# PROXY_URL=http://scrapeops.sticky_session=7:API_KEY@residential-proxy.scrapeops.io:8181
#
# ProxyEmpire:
# Use your dashboard-generated username; the agent appends/replaces an 8-digit sid.
# PROXY_PROVIDER=proxyempire
# PROXY_URL=http://your-dashboard-username:password@res.proxyempire.io:9000
#
# IPRoyal:
# Sticky session tokens live in the password.
# PROXY_PROVIDER=iproyal
# PROXY_URL=http://username:password_country-US_session-old_lifetime-10m@geo.iproyal.com:12321
#
# Webshare:
# Webshare stickiness is selected on the provider side; credentials are passed through.
# PROXY_PROVIDER=webshare
# PROXY_URL=http://username:password@p.webshare.io:80
#
# PROXY_URL=http://user:pass@127.0.0.1:8080
PROXY_SCHEME=http
PROXY_HOST=127.0.0.1
PROXY_PORT=8080
# PROXY_USERNAME=your-username
# PROXY_PASSWORD=your-password

# Optional browser fingerprint alignment
# BROWSER_LOCALE=en-US
# BROWSER_TIMEZONE=America/New_York
# BROWSER_ACCEPT_LANGUAGE=en-US,en;q=0.9

DEBUG_ENABLED=false
