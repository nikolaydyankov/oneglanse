{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		/* 🚨 OVERRIDES */
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": false,
		"isolatedModules": true,
		"composite": true,
		"baseUrl": "../../",
		"paths": {
			"@oneglanse/utils": ["packages/utils/src/index.ts", "packages/utils/dist/index.d.ts"]
		},

		/* Output */
		"jsx": "react-jsx",
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist"],
	"references": [{ "path": "../utils" }]
}
